# Second Brain Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Frontend Configuration
# ============================================================================
# API endpoint that frontend will connect to
# Use this to configure the backend API URL without hardcoding it
API_BASE_URL=

# ============================================================================
# Database Configuration
# ============================================================================
POSTGRES_USER=secondbrain
POSTGRES_PASSWORD=securepass123
POSTGRES_DB=secondbrain

# ============================================================================
# LLM API Keys
# ============================================================================
OPENAI_API_KEY=your-openai-api-key-here
CLAUDE_API_KEY=your-claude-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
GROK_API_KEY=your-grok-api-key-here

# ============================================================================
# LLM Model Configuration
# ============================================================================
OPENAI_MODEL=gpt-5-mini
CLAUDE_MODEL=claude-3-5-sonnet-20241022
GEMINI_MODEL=gemini-2.0-flash-exp
GROK_MODEL=grok-4.3

# ============================================================================
# LLM Temperature Settings (0 = deterministic, 1 = creative)
# ============================================================================
OPENAI_TEMPERATURE=0
CLAUDE_TEMPERATURE=0
GEMINI_TEMPERATURE=0
GROK_TEMPERATURE=0

# ============================================================================
# Notion Integration (Optional)
# ============================================================================
NOTION_TOKEN=your-notion-integration-token
NOTION_DB_ID=your-notion-database-id
NOTION_DATE_COL=Date

# ============================================================================
# Agentic RAG Tuning
# ============================================================================
# Minimum similarity score for vector search results (default 0.6)
AGENTIC_SIM_THRESHOLD=0.6
# Maximum LangGraph iterations per query (default 2)
AGENTIC_MAX_ITERATIONS=2

# ===========================
# Test Mode Configuration
# ===========================

ENABLE_TEST_MODE=true
TEST_USER_ID=test-user-123
TEST_USER_EMAIL=test@example.com
TEST_USER_NAME=Test User

# ===========================
# LLM Timeout Configuration
# ===========================

# Timeout in seconds for LLM API calls (default: 120)
LLM_TIMEOUT=300

# Maximum retries for failed LLM requests (default: 2)
LLM_MAX_RETRIES=5

# Frontend timeout in seconds - should be higher than LLM_TIMEOUT (default: 150)
# This gives the backend time to complete before frontend times out
FRONTEND_TIMEOUT=320

# ===========================
# LLM Wiki Export
# ===========================

# Directory where the API stores uploaded image sources for Graphify-backed markdown export
SECOND_BRAIN_DATA_DIR=/app/data

# Directory where session export workspaces are written as /tmp/{session-id}
WIKI_EXPORT_TMP_ROOT=/tmp

# Timeout in seconds for Graphify extraction before falling back to a structured markdown download
GRAPHIFY_EXPORT_TIMEOUT=300

# Graphify extraction backend. Use openai to avoid Gemini free-tier quota limits.
GRAPHIFY_BACKEND=openai

# Optional extra CLI flags appended to graphify extract
GRAPHIFY_EXTRA_ARGS=

# Maximum number of session messages included in a markdown export
WIKI_EXPORT_MESSAGE_LIMIT=500
